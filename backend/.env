PORT=8080

# Opción 1 — URL completa (recomendada para producción/Docker)
DATABASE_URL="host=154.53.49.30 user=cac_user password=cdAEnueGTUqn7HFfjJDidxGQ8G2xzynDG4mgdMkZ8oG2hXyeGMtHFY9EWy2wr6PRcTvCPfHu8vrfEBmQFWtWGsCrDgvBvEAt7qjX dbname=cac port=5432 sslmode=disable TimeZone=UTC"

# Opción 2 — Variables individuales (se usan si DATABASE_URL no está definida)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=cac
DB_SSLMODE=disable

JWT_SECRET_ACCESS=change-me-access-secret-min-32-chars
JWT_SECRET_REFRESH=change-me-refresh-secret-min-32-chars

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234


kubectl exec -it postgres-ha-1 -n default -- psql -U postgres -c "
  CREATE DATABASE cac;
  CREATE USER cac_user WITH PASSWORD 'cdAEnueGTUqn7HFfjJDidxGQ8G2xzynDG4mgdMkZ8oG2hXyeGMtHFY9EWy2wr6PRcTvCPfHu8vrfEBmQFWtWGsCrDgvBvEAt7qjX';
  GRANT ALL PRIVILEGES ON DATABASE cac TO cac_user;
"
