{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "C&C",
  "version": "0.1.0",
  "identifier": "dev.guz-studio.cac",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Command & Control - Dwit México",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzQzlEOTRGNzNFODJDNTcKUldSWExPaHpUOW5KNDdLZzhYOFB6ZXpJU0lqdHNYWE80eHdqdUxyY2k3TWo0ZEd5cklCRE0zSHAK",
      "endpoints": [
        "https://github.com/RomanshkVolkov/c-c/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
